{
  "manifest_version": 3,
  "name": "QA Smart Assistant",
  "version": "3.2.0",
  "description": "AI-powered QA testing assistant with screen recording, voice transcription and smart bug reports.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.groq.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "review/review.html",
        "review/review.js",
        "review/review.css",
        "permissions/permissions.html",
        "permissions/permissions.js",
        "permissions/permissions.css",
        "recorder/recorder.html",
        "recorder/recorder.js",
        "recorder/recorder.css",
        "controlbar/controlbar.css",
        "controlbar/controlbar.js",
        "shared/jszip.min.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}